# Database — use Postgres in production (see docker-compose.yml)
DATABASE_URL=postgresql://nextlevel:nextlevel@localhost:5432/leads

# Scraping
SCRAPE_RATE_LIMIT_SECONDS=2
SCRAPE_USER_AGENT=NextLevelLeadBot/1.0 (+https://nextlevelstudio.com)
USE_PLAYWRIGHT_FOR_MAPS=true
SKIP_WEBSITE_RESOLUTION=true
SKIP_JOB_SIGNALS=true
MAX_COMPANIES_PER_JOB=25

# Auth (required for multi-user / production)
AUTH_REQUIRED=true
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRE_HOURS=72
ALLOW_REGISTRATION=false
ADMIN_EMAIL=admin@nextlevelstudio.com
ADMIN_PASSWORD=change-me-on-first-deploy
ADMIN_NAME=Admin

# Comma-separated frontend URLs (Vercel + local dev)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Google Sheets (optional)
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_SHEET_ID=

# Frontend (Vercel) — set in Vercel project env, not .env for API
# VITE_API_URL=
# VITE_ENTITY_ID=nextlevel

# Email canvas — Phase 2 (optional)
RESEND_API_KEY=
EMAIL_FROM=info@nextlevelstudio.com
EMAIL_FROM_NAME=Next Level Studio
